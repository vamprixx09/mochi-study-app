rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email in ['jeeqlin2013@gmail.com', 'vamprixx55@gmail.com']);
    }

    // 2. Validation Helpers
    function isValidUser(data) {
      // Relaxed for debugging but keeping core identity
      return data.uid is string && data.name is string;
    }

    function isValidUserData(data) {
      return true; // Simplified for robustness
    }

    // 3. Match Blocks
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && 
                      (incoming().uid == userId);
      allow update: if isOwner(userId) && 
                      (incoming().uid == userId);
    }

    match /userData/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidId(userId);

      match /parts/{partId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(partId);
      }
    }

    match /system/config {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
